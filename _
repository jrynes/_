const { execSync } = require('child_process');

try {
  // Run lint-staged
  console.log('Running lint-staged...');
  execSync('npx lint-staged', { stdio: 'inherit' });

  // Check for staged changes
  const stagedFiles = execSync('git diff --cached --name-only').toString().trim();
  if (stagedFiles) {
    console.log('Staged files found:', stagedFiles);
    // Create a new commit for lint fixes
    execSync('git commit -m "chore: apply lint fixes [lint-fix]"', { stdio: 'inherit' });
  } else {
    console.log('No staged changes after lint-staged.');
  }
} catch (error) {
  console.error('Post-commit hook failed:', error.message);
  process.exit(1);
}
