# Get a list of files with changes after lint-staged
CHANGED_FILES=$(git diff --cached --name-only)

# Check if there are any changes after fixes
if [ -n "$CHANGED_FILES" ]; then
  # Loop through each changed file and stage it
  echo "$CHANGED_FILES" | while read -r file; do
    git add "$file"
  done

  # Create a separate commit for the fixes
  git commit -m "chore: apply lint fixes"
fi
