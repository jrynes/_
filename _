#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Skip the hook if the commit message contains [lint-fix]
if git log -1 --pretty=%B | grep -q "\[lint-fix\]"; then
  echo "Skipping post-commit for lint-fix commit."
  exit 0
fi

# Get the list of files changed in the last commit
CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)

# Run linting and fixing on the files
echo "Processing the following files from the last commit:"
echo "$CHANGED_FILES"

# Run eslint/prettier/stylelint as needed
echo "$CHANGED_FILES" | while read -r file; do
  case "$file" in
    *.ts)
      npx eslint --fix "$file"
      ;;
    *.html)
      npx eslint --fix "$file"
      ;;
    *.css|*.scss)
      npx stylelint --fix "$file"
      ;;
  esac
done

# Check if there are any changes after linting
if [ -n "$(git diff --name-only)" ]; then
  echo "Staging linted files..."
  git add $CHANGED_FILES

  # Create a new commit for lint fixes
  git commit -m "chore: apply lint fixes [lint-fix]"
else
  echo "No changes detected after linting."
fi
