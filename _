
async checkUserSession(): Promise<boolean> {
  try {
    // Attempt to fetch the user's Okta session
    let sessionInfo = null;
    try {
      sessionInfo = await this.oktaAuth.session.get();
    } catch (error) {
      if (error.status === 404) {
        console.log('No active session found (404).');
      } else {
        console.error('Error fetching Okta Session:', error);
        return false; // Stop further processing in case of non-404 errors
      }
    }

    console.log('Session Info:', sessionInfo);

    // Check if the user is already authenticated
    const isAuthenticated = await this.oktaAuth.isAuthenticated();
    console.log('isAuthenticated:', isAuthenticated);

    // If there is an active session or the user is authenticated, return true
    if (
      (sessionInfo && sessionInfo.status === 'ACTIVE') ||
      isAuthenticated
    ) {
      console.log('User is logged in with an active session.');
      return true;
    }

    // If the user is not authenticated and no active session exists, redirect to login
    console.warn('No active session, and user is not authenticated. Redirecting to login...');
    this.oktaAuth.signInWithRedirect();
    return false;
  } catch (error) {
    console.error('Error checking user session:', error);
    return false; // Return false in case of any unexpected errors
  }
}
