// To delint one TS file, you can run as below
// tslint -c tslint.json your-file.ts
{
  // Extends the recommended TSLint ruleset, which includes a set of sensible defaults
  "extends": "tslint:recommended",

  // Specifies additional directories containing custom linting rules
  "rulesDirectory": [
    "codelyzer" // Adds Angular-specific linting rules from the codelyzer package
  ],

  // Custom linting rules
  "rules": {
    // Align parameters and statements for better readability
    "align": {
      "options": ["parameters", "statements"]
    },

    // Disable enforcement of array type declarations
    "array-type": false,

    // Require shorthand syntax for arrow function return statements where possible
    "arrow-return-shorthand": true,

    // Enforce braces for control statements, even when optional
    "curly": true,

    // Mark deprecated APIs with a warning instead of an error
    "deprecation": {
      "severity": "warning"
    },

    // Require files to end with a newline
    "eofline": true,

    // Blacklist certain imports to avoid usage
    "import-blacklist": [
      true,
      "rxjs/Rx" // Prevent importing everything from RxJS
    ],

    // Enforce consistent spacing in imports
    "import-spacing": true,

    // Enforce indentation with spaces
    "indent": {
      "options": ["spaces"]
    },

    // Allow multiple classes in a single file
    "max-classes-per-file": false,

    // Set the maximum line length to 140 characters
    "max-line-length": [true, 140],

    // Enforce specific member ordering in classes
    "member-ordering": [
      true,
      {
        "order": [
          "static-field",     // Static fields first
          "instance-field",   // Then instance fields
          "static-method",    // Then static methods
          "instance-method"   // Finally instance methods
        ]
      }
    ],

    // Allow console methods but restrict specific ones
    "no-console": [
      true,
      "debug", "info", "time", "timeEnd", "trace"
    ],

    // Allow empty blocks
    "no-empty": false,

    // Allow inferred types except for parameters
    "no-inferrable-types": [
      true,
      "ignore-params"
    ],

    // Disallow non-null assertion operator (!)
    "no-non-null-assertion": true,

    // Disallow redundant JSDoc comments
    "no-redundant-jsdoc": true,

    // Disallow fall-through in switch cases
    "no-switch-case-fall-through": true,

    // Allow require statements (common in Node.js)
    "no-var-requires": false,

    // Quote object keys only when necessary
    "object-literal-key-quotes": [
      true,
      "as-needed"
    ],

    // Enforce single quotes for strings
    "quotemark": [
      true,
      "single"
    ],

    // Enforce semicolons at the end of statements
    "semicolon": {
      "options": ["always"]
    },

    // Enforce spacing rules for function declarations
    "space-before-function-paren": {
      "options": {
        "anonymous": "never",
        "asyncArrow": "always",
        "constructor": "never",
        "method": "never",
        "named": "never"
      }
    },

    // Require typedefs for call signatures
    "typedef": [true, "call-signature"],

    // Configure whitespace rules for typedefs
    "typedef-whitespace": {
      "options": [
        {
          "call-signature": "nospace",
          "index-signature": "nospace",
          "parameter": "nospace",
          "property-declaration": "nospace",
          "variable-declaration": "nospace"
        },
        {
          "call-signature": "onespace",
          "index-signature": "onespace",
          "parameter": "onespace",
          "property-declaration": "onespace",
          "variable-declaration": "onespace"
        }
      ]
    },

    // Enforce specific naming conventions for variables
    "variable-name": {
      "options": [
        "ban-keywords",     // Ban JavaScript reserved keywords as variable names
        "check-format",     // Check for valid naming formats
        "allow-pascal-case" // Allow PascalCase for variables
      ]
    },

    // Enforce whitespace rules
    "whitespace": {
      "options": [
        "check-branch",      // Check spacing in branching statements
        "check-decl",        // Check spacing in declarations
        "check-operator",    // Check spacing around operators
        "check-separator",   // Check spacing in separators
        "check-type",        // Check spacing in type annotations
        "check-typecast"     // Check spacing in typecasts
      ]
    },

    // Angular-specific linting rules (from codelyzer)
    "component-class-suffix": true, // Enforce component class naming convention
    "contextual-lifecycle": true,  // Ensure lifecycle hooks are properly used
    "directive-class-suffix": true, // Enforce directive class naming convention
    "no-conflicting-lifecycle": true, // Disallow conflicting lifecycle hooks
    "no-host-metadata-property": true, // Disallow host metadata property
    "no-input-rename": true,         // Disallow renaming input bindings
    "no-inputs-metadata-property": true, // Disallow inputs metadata property
    "no-output-native": true,        // Disallow native outputs like `click`
    "no-output-on-prefix": true,     // Disallow output names starting with "on"
    "no-output-rename": true,        // Disallow renaming output bindings
    "no-outputs-metadata-property": true, // Disallow outputs metadata property
    "template-banana-in-box": true,  // Enforce proper use of [( )] syntax
    "template-no-negated-async": true, // Disallow negated async pipes
    "use-lifecycle-interface": true, // Enforce lifecycle interface implementation
    "use-pipe-transform-interface": true, // Enforce pipe transform interface
    "directive-selector": [
      true,
      "attribute", // Directives must use attribute selectors
      "app",       // Prefix for directives
      "camelCase"  // Use camelCase for naming
    ],
    "component-selector": [
      true,
      "element",    // Components must use element selectors
      "app",        // Prefix for components
      "kebab-case"  // Use kebab-case for naming
    ]
  }
}
