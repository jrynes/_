// General function to populate any table
function populateTable(tableId, data, columnNames) {
  var tableBody = document.getElementById(tableId).getElementsByTagName("tbody")[0];
  tableBody.innerHTML = ""; // Clear existing rows

  // Populate table with data
  data.forEach(function(record) {
    var row = tableBody.insertRow(); // Create a new row
    
    // Loop through each column name and insert a cell
    columnNames.forEach(function(col, index) {
      var cell = row.insertCell(index); // Create a new cell
      cell.textContent = record[col];  // Set cell's text content to the corresponding value
    });
  });
}

// General function to filter data based on date range
function filterData(data, startDate, endDate, dateField) {
  return data.filter(function(d) {
    var date = new Date(d[dateField]); // Use the provided date field for filtering
    return date >= startDate && date <= endDate;
  });
}

