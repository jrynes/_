"lint-staged": {
  "*.ts": ["prettier --write"],
  "*.html": ["prettier --write"],
  "*.css": ["prettier --write"],
  "*.scss": ["prettier --write"]
}


{
  "semi": true, // Add semicolons at the end of statements
  "singleQuote": true, // Use single quotes where applicable
  "tabWidth": 2, // Set the default indentation to 2 spaces
  "useTabs": false, // Use spaces instead of tabs
  "trailingComma": "es5", // Add trailing commas in ES5-compliant situations (e.g., objects, arrays)
  "printWidth": 80, // Limit lines to 80 characters for readability
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "tabWidth": 4, // Use 4 spaces for HTML indentation
        "singleQuote": false, // Use double quotes for HTML attributes
        "htmlWhitespaceSensitivity": "ignore", // Ignore whitespace sensitivity in HTML for consistent formatting
        "bracketSameLine": true // Place `>` of multi-line elements on the last line instead of a new line
      }
    },
    {
      "files": ["*.css", "*.scss"],
      "options": {
        "singleQuote": false, // Use double quotes for CSS/SCSS
        "tabWidth": 2, // Use 2 spaces for indentation
        "bracketSpacing": true, // Add spaces inside braces (e.g., `{ color: red; }`)
        "trailingComma": "none", // No trailing commas in CSS
        "printWidth": 100 // Allow slightly longer lines for CSS rules
      }
    },
    {
      "files": "*.ts",
      "options": {
        "semi": false, // Omit semicolons for TypeScript
        "singleQuote": true, // Use single quotes for TypeScript
        "bracketSpacing": true, // Add spaces inside object literals (e.g., `{ foo: bar }`)
        "trailingComma": "all", // Add trailing commas for easier diffing
        "arrowParens": "always", // Always include parentheses in arrow functions
        "printWidth": 80 // Limit lines to 80 characters for readability
      }
    }
  ]
}





